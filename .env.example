# =============================================================
# Uni-Scraper-Pipeline Environment Variables
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Required ---

# OpenAI API key for GPT-4o
OPENAI_API_KEY=sk-your-openai-api-key

# Supabase/PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host:5432/dbname

# API key for authenticating requests from the Next.js frontend
API_KEY=your-secret-api-key

# SerpAPI key for search-based scraping (university name → catalog URL)
# Get one at https://serpapi.com/  — required for search mode, optional for direct URL mode
SERP_API_KEY=your-serp-api-key

# --- Optional ---

# Environment: development, staging, production
ENVIRONMENT=development

# FastAPI server
HOST=0.0.0.0
PORT=8000

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000

# OpenAI model to use. Larger context models = less truncation of catalog pages.
# gpt-4o, gpt-4.1: 128k context (~100k for page content)
# gpt-5, gpt-5.1, gpt-5.2, gpt-5-mini: 400k context (~350k for page content)
OPENAI_MODEL=gpt-4o

# Override max page content tokens (optional). Auto-derived from model if unset.
# MAX_CONTENT_TOKENS=350000

# Token budget per scrape job (default: 2,000,000)
TOKEN_BUDGET=2000000

# Playwright browser pool size
BROWSER_POOL_SIZE=3

# Rate limiting: seconds between requests to the same domain
RATE_LIMIT_DELAY=2.0

# Page cache TTL in hours
CACHE_TTL_HOURS=24

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
